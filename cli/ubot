#!/usr/bin/env bash
# ubot — Personal AI Assistant CLI
# Usage: ubot <command>
set -e

# Ensure nvm-managed node is in PATH
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" 2>/dev/null || true

VERSION="1.0.0"
LOGO="🤖"

# ─── Paths ──────────────────────────────────────────────────────────────────────
UBOT_HOME="${UBOT_HOME:-$HOME/.ubot}"
UBOT_CONFIG="$UBOT_HOME/config.json"
UBOT_LIB="$UBOT_HOME/lib"
UBOT_WEB="$UBOT_HOME/web"
UBOT_DATA="$UBOT_HOME/data"
UBOT_LOGS="$UBOT_HOME/logs"
UBOT_PIDFILE="$UBOT_HOME/ubot.pid"

# ─── Helpers ────────────────────────────────────────────────────────────────────
die()  { echo "❌ $*" >&2; exit 1; }
info() { echo "$LOGO $*"; }

# Read a value from config.json (requires node)
config_get() {
  node -e "
    const fs = require('fs');
    try {
      const c = JSON.parse(fs.readFileSync('$UBOT_CONFIG', 'utf8'));
      const keys = '$1'.split('.');
      let v = c;
      for (const k of keys) { v = v?.[k]; }
      if (v !== undefined) process.stdout.write(String(v));
    } catch {}
  " 2>/dev/null
}

ensure_home() {
  if [ ! -d "$UBOT_HOME" ]; then
    info "First run — creating $UBOT_HOME ..."
    mkdir -p "$UBOT_HOME"
    mkdir -p "$UBOT_DATA"
    mkdir -p "$UBOT_LOGS"
    mkdir -p "$UBOT_HOME/sessions"
    mkdir -p "$UBOT_HOME/creds"
    mkdir -p "$UBOT_HOME/browser-profile"

    # Copy default config if we have one bundled
    local default_config
    default_config="$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")/default-config.json"
    if [ -f "$default_config" ]; then
      cp "$default_config" "$UBOT_CONFIG"
      info "Created default config at $UBOT_CONFIG"
    fi
  fi
}

is_running() {
  [ -f "$UBOT_PIDFILE" ] && kill -0 "$(cat "$UBOT_PIDFILE")" 2>/dev/null
}

# ─── Commands ───────────────────────────────────────────────────────────────────

cmd_start() {
  ensure_home

  if is_running; then
    local pid
    pid=$(cat "$UBOT_PIDFILE")
    info "Ubot is already running (PID $pid)"
    local port
    port=$(config_get server.port)
    port=${port:-11490}
    info "Dashboard: http://localhost:$port"
    exit 0
  fi

  # Verify installation
  [ -f "$UBOT_LIB/index.js" ] || die "Ubot is not installed. Run 'make install' from the source directory first."

  # Read config values for environment
  local port
  port=$(config_get server.port)
  port=${port:-11490}

  local llm_base_url llm_model llm_api_key google_api_key db_path serper_api_key
  llm_base_url=$(config_get llm.base_url)
  llm_model=$(config_get llm.model)
  llm_api_key=$(config_get llm.api_key)
  google_api_key=$(config_get llm.google_api_key)
  serper_api_key=$(config_get integrations.serper_api_key)
  db_path="$UBOT_DATA/ubot.db"

  info "Starting Ubot on port $port ..."

  # Export env vars that the backend reads
  PORT="$port" \
  NODE_ENV=production \
  DATABASE_PATH="$db_path" \
  LLM_BASE_URL="${llm_base_url}" \
  LLM_MODEL="${llm_model}" \
  LLM_API_KEY="${llm_api_key}" \
  GOOGLE_API_KEY="${google_api_key}" \
  SERPER_API_KEY="${serper_api_key}" \
  UBOT_HOME="$UBOT_HOME" \
  nohup node "$UBOT_LIB/index.js" \
    > "$UBOT_LOGS/ubot.log" 2>&1 &

  echo $! > "$UBOT_PIDFILE"

  sleep 2

  if is_running; then
    info "Ubot is running! (PID $(cat "$UBOT_PIDFILE"))"
    info "Dashboard: http://localhost:$port"
    info "Logs:      ubot logs"
  else
    die "Ubot failed to start. Check: ubot logs"
  fi
}

cmd_stop() {
  if ! is_running; then
    info "Ubot is not running."
    exit 0
  fi

  local pid
  pid=$(cat "$UBOT_PIDFILE")
  info "Stopping Ubot (PID $pid) ..."
  kill "$pid" 2>/dev/null || true

  # Wait up to 5 seconds for graceful shutdown
  for i in $(seq 1 10); do
    kill -0 "$pid" 2>/dev/null || break
    sleep 0.5
  done

  # Force kill if still running
  kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true

  rm -f "$UBOT_PIDFILE"
  info "Ubot stopped."
}

cmd_restart() {
  info "Restarting Ubot ..."
  cmd_stop
  sleep 1
  cmd_start
}

cmd_config() {
  local subcmd="${1:-}"
  case "$subcmd" in
    "")
      # Show current config
      if [ -f "$UBOT_CONFIG" ]; then
        cat "$UBOT_CONFIG"
      else
        die "No config file found at $UBOT_CONFIG"
      fi
      ;;
    edit)
      # Open config in editor
      local editor="${EDITOR:-${VISUAL:-nano}}"
      if [ ! -f "$UBOT_CONFIG" ]; then
        ensure_home
      fi
      info "Opening config in $editor ..."
      "$editor" "$UBOT_CONFIG"
      ;;
    set)
      # Set a config value: ubot config set <key> <value>
      local key="${2:-}"
      local val="${3:-}"
      [ -z "$key" ] && die "Usage: ubot config set <key> <value>"
      [ -z "$val" ] && die "Usage: ubot config set <key> <value>"
      if [ ! -f "$UBOT_CONFIG" ]; then
        ensure_home
      fi
      node -e "
        const fs = require('fs');
        const c = JSON.parse(fs.readFileSync('$UBOT_CONFIG', 'utf8'));
        const keys = '$key'.split('.');
        let obj = c;
        for (let i = 0; i < keys.length - 1; i++) {
          if (obj[keys[i]] === undefined) obj[keys[i]] = {};
          obj = obj[keys[i]];
        }
        let v = '$val';
        if (v === 'true') v = true;
        else if (v === 'false') v = false;
        else if (!isNaN(v) && v !== '') v = Number(v);
        obj[keys[keys.length - 1]] = v;
        fs.writeFileSync('$UBOT_CONFIG', JSON.stringify(c, null, 4) + '\\n');
      " 2>/dev/null || die "Failed to update config"
      info "Set $key = $val"
      ;;
    get)
      # Get a config value: ubot config get <key>
      local key="${2:-}"
      [ -z "$key" ] && die "Usage: ubot config get <key>"
      local val
      val=$(config_get "$key")
      if [ -n "$val" ]; then
        echo "$val"
      else
        die "Key '$key' not found in config"
      fi
      ;;
    path)
      echo "$UBOT_CONFIG"
      ;;
    *)
      echo "Unknown config subcommand: $subcmd"
      echo "Usage: ubot config [edit|set|get|path]"
      exit 1
      ;;
  esac
}

cmd_doctor() {
  local ok=true
  echo "$LOGO Ubot Doctor"
  echo ""

  # Check Node.js
  if command -v node &>/dev/null; then
    local node_ver
    node_ver=$(node --version 2>/dev/null)
    local major
    major=$(echo "$node_ver" | sed 's/v//' | cut -d. -f1)
    if [ "$major" -ge 22 ] 2>/dev/null; then
      echo "  ✅ Node.js $node_ver (>= 22)"
    else
      echo "  ⚠️  Node.js $node_ver (requires >= 22)"
      ok=false
    fi
  else
    echo "  ❌ Node.js not found"
    ok=false
  fi

  # Check installation
  if [ -f "$UBOT_LIB/index.js" ]; then
    echo "  ✅ Backend installed at $UBOT_LIB/"
  else
    echo "  ❌ Backend not installed (run 'make install')"
    ok=false
  fi

  # Check config
  if [ -f "$UBOT_CONFIG" ]; then
    if node -e "JSON.parse(require('fs').readFileSync('$UBOT_CONFIG','utf8'))" 2>/dev/null; then
      echo "  ✅ Config valid at $UBOT_CONFIG"
    else
      echo "  ❌ Config is invalid JSON: $UBOT_CONFIG"
      ok=false
    fi
  else
    echo "  ⚠️  No config file (will be created on first start)"
  fi

  # Check port availability
  local port
  port=$(config_get server.port 2>/dev/null)
  port=${port:-11490}
  if is_running; then
    echo "  ✅ Ubot is running on port $port (PID $(cat "$UBOT_PIDFILE"))"
  else
    if lsof -i:"$port" &>/dev/null; then
      echo "  ⚠️  Port $port is in use by another process"
    else
      echo "  ✅ Port $port is available"
    fi
  fi

  # Check data directory
  if [ -d "$UBOT_DATA" ]; then
    local db_size=""
    if [ -f "$UBOT_DATA/ubot.db" ]; then
      db_size=" ($(du -sh "$UBOT_DATA/ubot.db" 2>/dev/null | cut -f1 | xargs))" 
    fi
    echo "  ✅ Data directory exists$db_size"
  else
    echo "  ⚠️  No data directory yet"
  fi

  echo ""
  if $ok; then
    echo "  All checks passed! 🎉"
  else
    echo "  Some checks failed. Fix the issues above."
  fi
}

cmd_open() {
  local port
  port=$(config_get server.port)
  port=${port:-11490}
  local url="http://localhost:$port"

  if ! is_running; then
    info "Ubot is not running. Start it first: ubot start"
    exit 1
  fi

  info "Opening $url ..."
  if command -v open &>/dev/null; then
    open "$url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$url"
  else
    info "Open manually: $url"
  fi
}

cmd_status() {
  if is_running; then
    local pid port
    pid=$(cat "$UBOT_PIDFILE")
    port=$(config_get server.port)
    port=${port:-11490}
    info "Ubot is running"
    echo "  PID:       $pid"
    echo "  Port:      $port"
    echo "  Dashboard: http://localhost:$port"
    echo "  Home:      $UBOT_HOME"
    echo "  Logs:      $UBOT_LOGS/ubot.log"
  else
    info "Ubot is not running."
    [ -f "$UBOT_PIDFILE" ] && rm -f "$UBOT_PIDFILE"
  fi
}

cmd_logs() {
  local log_file="$UBOT_LOGS/ubot.log"
  if [ ! -f "$log_file" ]; then
    info "No log file found at $log_file"
    exit 0
  fi
  # Follow mode with -f flag, or just show last 50 lines
  if [ "${1:-}" = "-f" ] || [ "${1:-}" = "--follow" ]; then
    tail -f "$log_file"
  else
    tail -50 "$log_file"
  fi
}

cmd_version() {
  echo "$LOGO ubot v$VERSION"
  echo "  Home: $UBOT_HOME"
  echo "  Node: $(node --version 2>/dev/null || echo 'not found')"
}

cmd_help() {
  echo "$LOGO ubot — Personal AI Assistant v$VERSION"
  echo ""
  echo "Usage: ubot <command>"
  echo ""
  echo "Commands:"
  echo "  start                  Start Ubot (creates ~/.ubot on first run)"
  echo "  stop                   Stop Ubot"
  echo "  restart                Stop + start Ubot"
  echo "  status                 Show running status"
  echo "  logs [-f]              Show logs (use -f to follow)"
  echo "  config                 Show current config"
  echo "  config edit            Open config in \$EDITOR"
  echo "  config set <key> <val> Set a config value"
  echo "  config get <key>       Get a config value"
  echo "  config path            Show config file path"
  echo "  doctor                 Health check"
  echo "  open                   Open dashboard in browser"
  echo "  version                Show version info"
  echo ""
  echo "Environment:"
  echo "  UBOT_HOME   Override home directory (default: ~/.ubot)"
}

# ─── Main ───────────────────────────────────────────────────────────────────────
command="${1:-}"

case "$command" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    shift; cmd_logs "$@" ;;
  config)  shift; cmd_config "$@" ;;
  doctor)  cmd_doctor ;;
  open)    cmd_open ;;
  version) cmd_version ;;
  help|--help|-h) cmd_help ;;
  "")      cmd_help; exit 1 ;;
  *)       echo "Unknown command: $command"; cmd_help; exit 1 ;;
esac
