{
    "server": {
        "port": 11490
    },
    "database": {
        "path": "data/ubot.db"
    },
    "owner": {
        "phone": "",
        "telegram_id": "",
        "telegram_username": ""
    },
    "channels": {
        "whatsapp": {
            "enabled": false,
            "auto_reply": false
        },
        "telegram": {
            "enabled": false,
            "token": "",
            "auto_reply": false
        },
        "imessage": {
            "enabled": false,
            "server_url": "",
            "password": "",
            "auto_reply": false
        }
    },
    "agent": {
        "max_history_messages": 20
    },
    "meta": {
        "version": "3.0"
    },
    "defaults": {
        "chat": "models.gemini",
        "search": "search.duckduckgo",
        "cli": "cli.gemini",
        "email": "google.gmail",
        "calendar": "google.calendar",
        "maps": "google.places",
        "documents": "google.docs",
        "spreadsheets": "google.sheets",
        "storage": "google.drive",
        "contacts": "google.contacts"
    },
    "capabilities": {
        "models": {
            "enabled": true,
            "default": "gemini",
            "providers": {
                "gemini": {
                    "enabled": true,
                    "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai/",
                    "apiKey": "",
                    "model": "models/gemini-2.0-flash"
                },
                "ollama": {
                    "enabled": true,
                    "baseUrl": "http://localhost:11434/v1",
                    "model": "glm-4"
                }
            }
        },
        "search": {
            "enabled": true,
            "default": "duckduckgo",
            "providers": {
                "serper": {
                    "enabled": false,
                    "apiKey": ""
                },
                "duckduckgo": {
                    "enabled": true
                }
            }
        },
        "cli": {
            "enabled": true,
            "default": "gemini",
            "providers": {
                "gemini": {
                    "enabled": true,
                    "timeout": 300000
                },
                "ollama": {
                    "enabled": true,
                    "timeout": 300000
                }
            }
        },
        "filesystem": {
            "enabled": true,
            "allowed_paths": []
        },
        "google": {
            "enabled": false,
            "apiKey": "",
            "services": {
                "calendar": {
                    "enabled": true,
                    "credentials": {
                        "client_id": "",
                        "client_secret": "",
                        "redirect_uris": [
                            "http://localhost:11490/oauth2callback"
                        ]
                    }
                },
                "gmail": {
                    "enabled": true,
                    "credentials": {
                        "client_id": "",
                        "client_secret": "",
                        "redirect_uris": [
                            "http://localhost:11490/oauth2callback"
                        ]
                    }
                }
            }
        },
        "apple": {
            "enabled": true,
            "services": {
                "calendar": {
                    "enabled": true
                },
                "contacts": {
                    "enabled": true
                },
                "notes": {
                    "enabled": true
                },
                "mail": {
                    "enabled": true
                }
            }
        },
        "mcp": {
            "enabled": true,
            "servers": {}
        },
        "browser": {
            "enabled": true
        },
        "memory": {
            "enabled": true
        },
        "vault": {
            "enabled": true
        },
        "media": {
            "enabled": true
        }
    }
}