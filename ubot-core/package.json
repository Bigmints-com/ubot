{
  "name": "ubot-core",
  "version": "1.0.0",
  "description": "Empty TypeScript project skeleton. Just the build tooling, entry point, and dev scripts. Nothing else.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:css\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "build": "npm run build:css && npm run build:ts",
    "build:ts": "tsc",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "start": "node dist/index.js",
    "clean": "rm -rf dist public/css/output.css",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "typescript",
    "node",
    "skeleton"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "*"
  },
  "devDependencies": {
    "@types/node": "*",
    "autoprefixer": "*",
    "concurrently": "*",
    "postcss": "*",
    "tailwindcss": "*",
    "tslib": "*",
    "typescript": "*",
    "tsx": "*",
    "vitest": "*"
  }
}