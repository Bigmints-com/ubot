/**
 * UBOT Custom Tool Module — Boilerplate Template
 * 
 * This template defines the structure for a custom tool module.
 * CLI agents (Gemini, Claude, Codex) use this as a starting point
 * when generating new capabilities for UBOT.
 * 
 * RULES:
 * 1. Export a default object satisfying the ToolModule interface
 * 2. Every tool must have a unique name (no collisions with core tools)
 * 3. All tool names MUST be prefixed with 'custom_' to avoid conflicts
 * 4. Use proper types — import ToolModule, ToolRegistry, ToolContext from types
 * 5. Return { toolName, success, result, duration } from every executor
 */

import type { ToolModule, ToolRegistry, ToolContext, ToolDefinition } from '../../src/tools/types.js';

// ─── Tool Definitions ───────────────────────────────────
// These are exposed to the LLM and describe what each tool does

const TOOL_DEFINITIONS: ToolDefinition[] = [
  {
    name: 'custom_example',
    description: 'A brief, clear description of what this tool does. The LLM reads this to decide when to use the tool.',
    parameters: [
      { name: 'input', type: 'string', description: 'The input to process', required: true },
      { name: 'option', type: 'string', description: 'An optional parameter', required: false },
    ],
  },
  // Add more tool definitions here
];

// ─── Module Export ──────────────────────────────────────
// This is the main export — must satisfy ToolModule interface

const customModule: ToolModule = {
  name: 'custom-example',     // Unique module name
  tools: TOOL_DEFINITIONS,

  register(registry: ToolRegistry, _ctx: ToolContext) {
    // ── Tool Executors ──────────────────────────────────
    // Register an executor for each tool defined above

    registry.register('custom_example', async (args) => {
      const input = String(args.input || '');
      const _option = args.option ? String(args.option) : undefined;

      // ── Your implementation here ──────────────────
      // Access UBOT services via _ctx if needed:
      //   _ctx.getScheduler()      — scheduler service
      //   _ctx.getSkillEngine()    — skill engine
      //   _ctx.getWorkspacePath()  — workspace directory
      //   _ctx.getAgent()          — agent orchestrator

      const result = `Processed: ${input}`;

      return {
        toolName: 'custom_example',
        success: true,
        result,
        duration: 0,
      };
    });

    // Register more executors here...
  },
};

export default customModule;
